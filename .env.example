# Weather App Configuration

# API Endpoints (no secrets needed - public APIs)
WTTR_API_BASE=https://wttr.in
OPENMETEO_API_BASE=https://air-quality-api.open-meteo.com

# Default Location
DEFAULT_CITY=Częstochowa

# App Settings
LOG_LEVEL=info
CACHE_TTL_MINUTES=30

# Build Configuration
ANDROID_SDK_VERSION=35
TARGET_SDK_VERSION=34
MIN_SDK_VERSION=23
